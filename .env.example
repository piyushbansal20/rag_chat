# ===========================================
# IntelliChat - Environment Configuration
# ===========================================

# Required: Anthropic API Key (Claude AI)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Required: Voyage AI API Key (Embeddings & Reranking)
VOYAGE_API_KEY=pa-your-voyage-api-key

# Required: JWT Secrets (change these in production!)
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters-long
